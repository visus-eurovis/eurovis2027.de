---
import '../styles/global.css';
import DSGVO from '../components/dsgvo.md';

const { frontmatter } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<!--<link rel="icon" type="image/svg+xml" href= {import.meta.env.BASE_URL + "/favicon.svg"}/> -->
		<link rel="icon" href= {import.meta.env.BASE_URL + "/favicon.ico"} />
		<meta name="generator" content={Astro.generator} />
    <!-- <link rel="stylesheet" href= {import.meta.env.BASE_URL +"/src/styles/global.css"} /> -->
		<title>{frontmatter.title}</title>
	</head>
	<body>

    <div class="dsgvo">
      <DSGVO />
    </div>

    <h1>{frontmatter.title}</h1>

    <h2>{frontmatter.description}</h2>

    <div class="content">
      <slot />
		</div>
    
	</body>
</html>


<!-- Here, astro prepends BASE_URL automatically to font urls -->
<style is:global>

@font-face {
  font-family: 'Satoshi-Light';
  src: url('/fonts/Satoshi/Satoshi-Light.woff2') format('woff2'),
       url('/fonts/Satoshi/Satoshi-Light.woff') format('woff'),
       url('/fonts/Satoshi/Satoshi-Light.ttf') format('truetype');
  font-weight: 300;
  font-display: swap;
  font-style: normal;
}

html,
body {
  font-family: 'Satoshi-Light', system-ui, -apple-system, sans-serif;
}

</style>
